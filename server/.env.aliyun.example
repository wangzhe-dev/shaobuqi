PORT=3000
NODE_ENV=production

# 阿里云 RDS 连接信息（从阿里云控制台获取）
DB_HOST=rm-xxxxxxxxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=shaobuqi
DB_PASSWORD=replace_with_real_password
DB_NAME=shaobuqi
DB_CONNECTION_LIMIT=20

# 生产请替换为强随机串
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# 你的前端访问域名（可多个，用逗号分隔时请在代码中自行扩展）
CORS_ORIGIN=https://your-frontend-domain.com

# MinIO 配置
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=replace_with_minio_access_key
MINIO_SECRET_KEY=replace_with_minio_secret_key
MINIO_BUCKET=shaobuqi
MINIO_PUBLIC_BASE_URL=http://file.shaobuqi.com/shaobuqi
