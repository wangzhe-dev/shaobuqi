{
	"pages": [{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "uni-app"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "我的"
			}
		}
	],
	"easycom": {
		"custom": {
			"^sar-(.*)": "sard-uniapp/components/$1/$1.vue"
		}
	},
	"globalStyle": {
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#FF6E26",
		"backgroundColor": "#F8F8F8",
		// #ifdef H5
		"navigationStyle": "custom",
		// #endif
		"app-plus": {
			// #ifdef H5
			"titleNView": false,
			// #endif
			"background": "#efeff4",
			"scrollIndicator": "none",
			"bounce": "none"
		}
	},
	"tabBar": {
		"color": "#ADB2C1",
		"selectedColor": "#FF6E26",
		"borderStyle": "white",
		"backgroundColor": "#ffffff",
		// #ifdef APP-PLUS
		"iconWidth": "24px",
		"fontSize": "10px",
		// #endif
		"list": [{
				"pagePath": "pages/index/index",
				"iconPath": "static/images/tabbar/index.png",
				"selectedIconPath": "static/images/tabbar/index-select.png",
				"text": "首页"
			},
			{
				"pagePath": "pages/my/my",
				"iconPath": "static/images/tabbar/my.png",
				"selectedIconPath": "static/images/tabbar/my-select.png",
				"text": "我的"
			}
		]
	}
}