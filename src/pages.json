{
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/community/index",
			"style": {
				"navigationBarTitleText": "趋势",
				"navigationBarBackgroundColor": "#0B0D12",
