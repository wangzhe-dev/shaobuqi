				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/publish/index",
			"style": {
				"navigationBarTitleText": "发布",
				"navigationBarBackgroundColor": "#0B0D12",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/skill/index",
			"style": {
				"navigationBarTitleText": "Skill",
				"navigationBarBackgroundColor": "#0B0D12",
				"navigationBarTextStyle": "white",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationStyle": "custom",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/detail/post",
			"style": {
				"navigationBarTitleText": "",
				"navigationBarBackgroundColor": "#0B0D12",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/detail/skill",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/author/index",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/search/index",
			"style": {
				"navigationBarTitleText": "搜索",
				"navigationBarBackgroundColor": "#0B0D12",
				"navigationBarTextStyle": "white"
			}
		}
	],
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			"^sar-(.*)": "sard-uniapp/components/$1/$1.vue",
			"^tab-bar$": "@/components/tab-bar/index.vue"
		}
	},
	"globalStyle": {
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "烧不起",
		"navigationBarBackgroundColor": "#0B0D12",
		"backgroundColor": "#0B0D12",
		"app-plus": {
			"background": "#0B0D12",
			"scrollIndicator": "none",
			"bounce": "none"
		}
	},
	"tabBar": {
		"custom": true,
		"color": "rgba(255,255,255,0.45)",
		"selectedColor": "#FF7A1A",
		"borderStyle": "black",
		"backgroundColor": "#141922",
		"list": [
			{
				"pagePath": "pages/index/index",
				"iconPath": "static/images/tabbar/index.png",
				"selectedIconPath": "static/images/tabbar/index-select.png",
				"text": "首页"
			},
			{
				"pagePath": "pages/community/index",
				"iconPath": "static/images/tabbar/community.png",
				"selectedIconPath": "static/images/tabbar/community-select.png",
				"text": "烧榜"
			},
			{
				"pagePath": "pages/publish/index",
				"iconPath": "static/images/tabbar/publish.png",
				"selectedIconPath": "static/images/tabbar/publish-select.png",
				"text": "发布"
			},
			{
				"pagePath": "pages/skill/index",
				"iconPath": "static/images/tabbar/skill.png",
				"selectedIconPath": "static/images/tabbar/skill-select.png",
				"text": "Skill"
			},
			{
				"pagePath": "pages/my/my",
				"iconPath": "static/images/tabbar/my.png",
				"selectedIconPath": "static/images/tabbar/my-select.png",
				"text": "我的"
			}
		]
