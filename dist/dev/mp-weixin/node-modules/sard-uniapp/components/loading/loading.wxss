0{opacity:.8333;transform:rotate(300deg)}.sar-loading__scale_11{opacity:.9167;transform:rotate(330deg)}.sar-loading__scale_12{opacity:1;transform:rotate(360deg)}.sar-loading__scale_hidden{opacity:0}.sar-loading__text{position:relative;box-sizing:border-box;display:flex;flex-direction:column;margin-left:var(--sar-loading-text-margin-left)}.sar-loading_vertical .sar-loading__text{margin-left:0;margin-top:var(--sar-loading-text-vertical-margin-top)}
