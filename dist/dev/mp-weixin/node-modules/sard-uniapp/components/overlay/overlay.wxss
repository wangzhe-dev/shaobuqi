.sar-overlay{position:relative;box-sizing:border-box;display:flex;flex-direction:column;position:fixed;top:0;left:0;right:0;bottom:0;z-index:var(--sar-overlay-z-index);background:var(--sar-overlay-bg);touch-action:none}.sar-overlay_enter-from,.sar-overlay_leave-to{opacity:0}.sar-overlay_enter-active,.sar-overlay_leave-active{transition:opacity var(--sar-overlay-duration) ease}.sar-overlay_transparent{background-color:transparent}
