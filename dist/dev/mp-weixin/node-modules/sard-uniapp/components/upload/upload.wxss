.sar-upload{position:relative;box-sizing:border-box;display:flex;flex-direction:column}.sar-upload__wrapper{position:relative;box-sizing:border-box;display:flex;flex-direction:column;flex-direction:row;flex-wrap:wrap;gap:var(--sar-upload-preview-gap)}.sar-upload__select{position:relative;box-sizing:border-box;display:flex;flex-direction:column;align-items:center;justify-content:center;width:var(--sar-upload-select-width);height:var(--sar-upload-select-height);color:var(--sar-upload-select-color);border-radius:var(--sar-upload-select-border-radius);background:var(--sar-upload-select-bg);cursor:pointer}.sar-upload__select-icon{font-size:var(--sar-upload-select-font-size);line-height:var(--sar-leading-none)}.sar-upload:not(.sar-upload_disabled):not(.sar-upload_readonly) .sar-upload__select:active{background:var(--sar-upload-select-active-bg)}.sar-upload_disabled .sar-upload__select{color:var(--sar-disabled-color);cursor:var(--sar-disabled-cursor)}.sar-upload_readonly .sar-upload__select{cursor:unset}
